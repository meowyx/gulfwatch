# GulfWatch configuration. Copy to `.env` and fill in the blanks.
#
# MONITOR_PROGRAMS is comma-separated. Use it to watch a protocol family
# (Raydium has four programs, Jupiter has several) or to mix protocols with
# Token 2022. MONITOR_PROGRAM (singular) is still accepted as a one-program
# fallback, but MONITOR_PROGRAMS is the recommended form.

# ─── DEVNET ─────────────────────────────────────────────────
SOLANA_WS_URL=
SOLANA_RPC_URL=
MONITOR_PROGRAMS=TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA
WATCHED_ACCOUNTS=


# ─── MAINNET ────────────────────────────────────────────────
# Uncomment and fill in when you're ready to switch. Replace YOUR_KEY
# with your Helius (or any Solana RPC) API key.
#
# SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# YOU CAN ADD YOUR OWN PROGRAM TO MONITOR
MONITOR_PROGRAMS=TokenzQdBNbLqP5VEhdkAS6EPFLC1PHnBqCXEpPxuEb,675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8,CAMMCzo5YL8w4VFF8KVHrK22GGUsp5VTaW7grrKgrWqK,CPMMoo8L3F4NbTegBCKVNunggL7H1ZpdTHKxQB5qKP1C,JUP6LkbZbjS1jKKwapdHNy74zcZ3tLUZoi5QNyVTaV4

WATCHED_ACCOUNTS=DQyrAcCrDXQ7NeoqGgDCZwBvWDcYmFCjSb1JtteuC5BZ,HLmqeL62xR1QoZ1HKKbXRrdN1p3phKpxRMb2VVopvBBz
LARGE_TRANSFER_THRESHOLD=10000000000
ROLLING_WINDOW_MINUTES=10
CORRELATION_MIN_PROGRAMS=3
CORRELATION_WINDOW_SECS=300
